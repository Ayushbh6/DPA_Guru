# Database (required for migrations / registry CLI)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres

# LLM providers (optional until you use draft generation)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_CHECKLIST_MODEL=gemini-3-flash-preview
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional storage backend (if unset, registry uses local file storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Upload parse API (V1 beta)
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_OCR_MODEL=mistral-ocr-latest
MAX_UPLOAD_MB=50
UPLOAD_STORAGE_DIR=.registry_storage/uploads
PARSED_STORAGE_DIR=.registry_storage/parsed
TOKENIZER_ENCODING=cl100k_base
API_HOST=0.0.0.0
API_PORT=8001
DEFAULT_DEV_TENANT_ID=00000000-0000-0000-0000-000000000001
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001
